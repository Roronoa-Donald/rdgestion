# ============================================
# RDGESTION — Variables d'environnement
# ============================================
# Copiez ce fichier en .env pour le développement local :
#   cp .env.example .env
#
# Pour Vercel : configurez ces variables dans
#   Dashboard > Project > Settings > Environment Variables
# ============================================

# --- Base de données PostgreSQL ---
# En local : utilisez docker-compose (voir docker-compose.yml)
# En production : configurez une URL PostgreSQL managée dans l'hébergeur.
DATABASE_URL=postgresql://rdgestion_user:rdgestion_password@localhost:5432/rdgestion_db

# --- Authentification JWT ---
JWT_SECRET=votre_secret_jwt_ultra_securise_ici
JWT_EXPIRES_IN=24h

# --- Serveur ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# --- CORS ---
# En local : http://localhost:8080
# Sur Vercel : votre domaine Vercel (ex: https://rdgestion.vercel.app)
CORS_ORIGIN=http://localhost:8080

# --- Rate Limiting ---
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# --- Uploads ---
UPLOAD_MAX_SIZE=2097152
UPLOAD_DIR=./uploads

# --- Super Administrateur ---
SUPERADMIN_PHONE=+22890000000
SUPERADMIN_PASSWORD=ChangeMe123!
